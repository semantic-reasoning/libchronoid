#ifndef CHRONOID_VERSION_H
#define CHRONOID_VERSION_H

#define CHRONOID_VERSION_MAJOR  @VERSION_MAJOR@
#define CHRONOID_VERSION_MINOR  @VERSION_MINOR@
#define CHRONOID_VERSION_PATCH  @VERSION_PATCH@

/* Single integer suitable for `#if CHRONOID_VERSION >= ...` checks.
 * Layout: bits 16-23 major, 8-15 minor, 0-7 patch. */
#define CHRONOID_VERSION                           \
  ((CHRONOID_VERSION_MAJOR << 16)                  \
 | (CHRONOID_VERSION_MINOR <<  8)                  \
 | (CHRONOID_VERSION_PATCH      ))

/* Full version string verbatim from meson.project_version(); may
 * contain a pre-release suffix (e.g. "0.2.0-rc1") that the integer
 * macros above do not encode. */
#define CHRONOID_VERSION_STRING "@VERSION_STRING@"

#endif /* CHRONOID_VERSION_H */
